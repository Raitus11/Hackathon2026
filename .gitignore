# ─────────────────────────────────────────────────────────────────────
# Secrets — NEVER commit these
# ─────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets/
credentials/

# ─────────────────────────────────────────────────────────────────────
# Hackathon / project-specific data
# ─────────────────────────────────────────────────────────────────────
# Real customer CSVs should NEVER be committed
uploads/
raw_data*.csv
raw_data*.xlsx
*.bak
sessions/
session_*/

# Solver / pipeline run outputs
outputs/
output/
out/
tmp/
temp/
*.zip

# Demo recordings
*.mp4
*.mov

# ─────────────────────────────────────────────────────────────────────
# Python
# ─────────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
*.egg
.eggs/
.python-version
pip-log.txt
pip-delete-this-directory.txt

# Virtual envs
.venv/
venv/
env/
.tox/

# Test / coverage / lint caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
.hypothesis/
coverage.xml
*.cover

# Build artifacts (Python)
dist/
build/
sdist/
wheels/
*.whl

