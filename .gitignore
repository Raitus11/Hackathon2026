# ─────────────────────────────────────────────────────────────────────
node_modules/
.next/
.cache/
.parcel-cache/
.turbo/
.vite/

# npm / yarn / pnpm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build artifacts (frontend)
# (dist/ and build/ already covered above)

# ─────────────────────────────────────────────────────────────────────
